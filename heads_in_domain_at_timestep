    sp_zero = target_stress_period - 1
    ts_zero = target_timestep - 1
    target_tuple = (ts_zero, sp_zero)

    try:
        idx = kstpkper.index(target_tuple)
        actual_day = times[idx]

        print(f"Method: Stress Period & Timestep")
        print(f"Target: SP {target_stress_period}, TS {target_timestep}")
        print(f"Found at Day: {actual_day:.1f}")
        print(f"Index: {idx}")

        output_label = f"SP{target_stress_period}_TS{target_timestep}"
    except ValueError:
        print(f"ERROR: Stress Period {target_stress_period}, Timestep {target_timestep} not found!")
        print(f"Available SP range: 1 to {max([sp for ts, sp in kstpkper]) + 1}")
        exit()

elif use_method == "date":
    # Convert date to days from start
    start = pd.to_datetime(simulation_start_date)
    target = pd.to_datetime(target_date)
    days_from_start = (target - start).days

    # Find closest time
    idx = np.argmin(np.abs(np.array(times) - days_from_start))
    actual_day = times[idx]
    sp, ts = kstpkper[idx]
    actual_date = start + pd.Timedelta(days=actual_day)

    print(f"Method: Date")
    print(f"Target date: {target_date}")
    print(f"Days from start: {days_from_start}")
    print(f"Closest match: Day {actual_day:.1f} ({actual_date.strftime('%Y-%m-%d')})")
