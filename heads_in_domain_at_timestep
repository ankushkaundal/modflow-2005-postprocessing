utm_yll = 2630000
delr = 300
delc = 300

# -------------------------------------------------------
# LOAD HEAD FILE AND GET GRID DIMENSIONS
# -------------------------------------------------------
head_file_path = os.path.join(model_ws, f"{model_name}.hed")
if not os.path.exists(head_file_path):
    print(f"ERROR: Head file not found at {head_file_path}")
    exit()

head_file = HeadFile(head_file_path)
times = head_file.get_times()
kstpkper = head_file.get_kstpkper()

# Get grid dimensions
first_head = head_file.get_data(kstpkper=kstpkper[0])
nlay, nrow, ncol = first_head.shape

total_cells = nrow * ncol

print("=" * 70)
print("MODFLOW HEAD EXTRACTOR - ALL CELLS")
print("=" * 70)
print(f"Grid dimensions: {nrow} rows x {ncol} cols")
print(f"Total cells in layer {layer_to_extract}: {total_cells}")
print(f"Total time steps: {len(times)}")
print(f"Time range: {times[0]:.1f} to {times[-1]:.1f} days")

# -------------------------------------------------------
# FIND THE TARGET TIMESTAMP INDEX
# -------------------------------------------------------
print("\n" + "=" * 70)
print("FINDING TARGET TIMESTAMP")
print("=" * 70)

if use_method == "day":
    # Find closest time to target day
    idx = np.argmin(np.abs(np.array(times) - target_day))
    actual_day = times[idx]
    sp, ts = kstpkper[idx]

    print(f"Method: Cumulative Day")
    print(f"Target day: {target_day}")
    print(f"Closest match: Day {actual_day:.1f}")
    print(f"Index: {idx}")
    print(f"Stress Period: {sp + 1}, Timestep: {ts + 1}")

    output_label = f"Day_{int(actual_day)}"

elif use_method == "stress_period":
