    output_label = target_date.replace("-", "")

else:
    print(f"ERROR: Invalid method '{use_method}'. Use 'day', 'stress_period', or 'date'")
    exit()

# -------------------------------------------------------
# EXTRACT HEAD DATA FOR ALL CELLS
# -------------------------------------------------------
print("\n" + "=" * 70)
print("EXTRACTING HEAD DATA FOR ALL CELLS")
print("=" * 70)

# Load head data for the target timestamp
head_array = head_file.get_data(kstpkper=kstpkper[idx])[layer_to_extract]

# Create list to store all cell data
all_cells_data = []

print(f"Processing {total_cells} cells...")

# Loop through all cells in the grid
for row in range(nrow):
    for col in range(ncol):
        # Calculate 1-indexed cell ID
        cell_id = row * ncol + col + 1

        # Get head value
        head_value = head_array[row, col]

        # Skip inactive/dry cells (values <= -999 or exactly 0 which often means inactive)
        if head_value <= -999:
            continue

        # Calculate UTM coordinates (cell center)
        x_utm = utm_xll + (col + 0.5) * delr
        y_utm = utm_yll + (row + 0.5) * delc

        all_cells_data.append({
            'Cell_ID': cell_id,
            'Row': row,
            'Col': col,
            'X_UTM': x_utm,
            'Y_UTM': y_utm,
            'Head_m': head_value
        })

    # Progress indicator every 10 rows
    if (row + 1) % 10 == 0:
        print(f"  Processed {(row + 1) * ncol} / {total_cells} cells...")

print(f"✓ Extracted {len(all_cells_data)} active cells (skipped {total_cells - len(all_cells_data)} inactive cells)!")

